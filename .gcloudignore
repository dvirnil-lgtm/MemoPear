# Controls what gets uploaded by `gcloud run deploy --source .` / `gcloud builds submit`.
# Without this file, gcloud falls back to .gitignore, which excludes .env —
# but the Vite build needs .env so the Firebase config is baked into the bundle.
# .env is uploaded to Cloud Build only; it is still never committed to git.

.git/
.gitignore
node_modules/
dist/
.vscode/
.idea/
*.log
.DS_Store
